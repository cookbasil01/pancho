---
import { siteData } from '../data/site';
---

<section class="testimonials">
  <div class="container">
    <div class="text-center">
      <h2 class="section-title">Lo que dicen de nosotros</h2>
      <p class="section-subtitle">Nuestra mejor garantía es la satisfacción de quienes nos visitan en Los Alpes.</p>
    </div>
    
    <div class="testimonials-grid">
      {siteData.testimonials.map(testimonial => (
        <div class="testimonial-card">
          <div class="stars">
            {Array(testimonial.rating).fill('⭐').join('')}
          </div>
          <p class="quote">"{testimonial.text}"</p>
          <div class="author">
            <div class="avatar">{testimonial.name.charAt(0)}</div>
            <div>
              <strong>{testimonial.name}</strong>
              <div class="verified">✓ Cliente verificado</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials {
    background-color: var(--bg-dark);
    background-image: radial-gradient(circle at center, rgba(232, 90, 25, 0.05) 0%, transparent 70%);
  }
  
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }
  
  .testimonial-card {
    background: var(--bg-card);
    padding: 2.5rem 2rem;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255,255,255,0.05);
    position: relative;
    box-shadow: var(--shadow-sm);
  }
  
  .testimonial-card::before {
    content: '"';
    position: absolute;
    top: 20px;
    right: 30px;
    font-size: 6rem;
    font-family: serif;
    color: rgba(255,255,255,0.03);
    line-height: 1;
  }
  
  .stars {
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }
  
  .quote {
    font-size: 1.125rem;
    line-height: 1.6;
    margin-bottom: 2rem;
    font-style: italic;
    color: var(--text-main);
  }
  
  .author {
    display: flex;
    align-items: center;
    gap: 1rem;
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: 1.5rem;
  }
  
  .avatar {
    width: 48px;
    height: 48px;
    background: var(--brand-primary);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-weight: bold;
    font-size: 1.25rem;
  }
  
  .verified {
    font-size: 0.75rem;
    color: #10b981;
    margin-top: 4px;
  }
</style>
