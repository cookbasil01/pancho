---
import { siteData } from '../data/site';
---

<section id="contacto" class="location-contact">
  <div class="container">
    <div class="contact-wrapper">
      <div class="contact-info">
        <h2 class="section-title">Encuéntranos</h2>
        <p class="section-subtitle" style="margin-left: 0;">Visítanos o haz tu pedido. Estamos listos para atenderte con la mejor energía.</p>
        
        <div class="info-list">
          <div class="info-item">
            <span class="icon">📍</span>
            <div>
              <h3>Dirección</h3>
              <p>{siteData.address}</p>
            </div>
          </div>
          
          <div class="info-item">
            <span class="icon">🕒</span>
            <div>
              <h3>Horarios</h3>
              <p>{siteData.hours}</p>
            </div>
          </div>
          
          <div class="info-item">
            <span class="icon">📞</span>
            <div>
              <h3>Teléfono / WhatsApp</h3>
              <p>{siteData.phone}</p>
            </div>
          </div>
        </div>
        
        <div class="contact-actions">
          <a href={`https://wa.me/${siteData.whatsapp}`} class="btn btn-primary" target="_blank" rel="noopener">Escribir al WhatsApp</a>
          <a href={siteData.social.instagram} class="btn btn-outline" target="_blank" rel="noopener">Síguenos en Instagram</a>
        </div>
      </div>
      
      <div class="map-container">
        <!-- Placeholder for map iframe -->
        <div class="map-placeholder">
          <div class="map-content">
            <span style="font-size: 3rem; margin-bottom: 1rem; display: block;">🗺️</span>
            <h3>{siteData.location}</h3>
            <p>Espacio preparado para integrar Google Maps</p>
            <a href={`https://maps.google.com/?q=${encodeURIComponent(siteData.address)}`} target="_blank" rel="noopener" class="btn btn-outline" style="margin-top: 1rem; background: var(--bg-card);">Abrir en Google Maps</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .location-contact {
    background-color: #141416;
  }
  
  .contact-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  
  .info-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-bottom: 3rem;
  }
  
  .info-item {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }
  
  .icon {
    font-size: 1.5rem;
    background: rgba(255,255,255,0.05);
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    flex-shrink: 0;
  }
  
  .info-item h3 {
    font-size: 1.125rem;
    margin-bottom: 0.25rem;
    color: white;
  }
  
  .info-item p {
    color: var(--text-muted);
    margin: 0;
    font-size: 1rem;
  }
  
  .contact-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  
  .map-container {
    height: 500px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    position: relative;
    border: 1px solid rgba(255,255,255,0.1);
    box-shadow: var(--shadow-lg);
  }
  
  .map-placeholder {
    width: 100%;
    height: 100%;
    background: #1c1c20;
    background-image: radial-gradient(rgba(255,255,255,0.1) 1px, transparent 1px);
    background-size: 20px 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  
  .map-content {
    background: rgba(20, 20, 22, 0.9);
    padding: 2rem;
    border-radius: var(--radius-md);
    border: 1px solid rgba(255,255,255,0.05);
  }
  
  @media (max-width: 992px) {
    .contact-wrapper {
      grid-template-columns: 1fr;
    }
    
    .map-container {
      height: 400px;
      order: -1; /* Map on top in mobile */
    }
  }
</style>
